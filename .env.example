# ─── Server ────────────────────────────────────────────────────────────────────
# Port the Next.js server listens on (default: 3000)
PORT=3000

# Internal URL used for server-to-server requests (e.g. session validation).
# Required when running behind a reverse proxy (Nginx, Caddy, Cloudflare) that
# terminates SSL — prevents the server from trying to call itself over HTTPS.
# Should point to the local HTTP address where Next.js is listening.
INTERNAL_URL=http://localhost:3000

# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=production
