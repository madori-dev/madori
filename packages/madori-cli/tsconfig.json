{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "declaration": true,
    "paths": {
      "@madori/lib/*": ["../../src/lib/*"],
      "@/*": ["../../src/*"]
    }
  },
  "include": ["src/**/*"]
}
