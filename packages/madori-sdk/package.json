{
  "name": "@madori/sdk",
  "version": "0.1.0",
  "description": "Typed content SDK for Madori CMS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hooks/server": {
      "types": "./dist/hooks/server.d.ts",
      "import": "./dist/hooks/server.js"
    },
    "./hooks/client": {
      "types": "./dist/hooks/client.d.ts",
      "import": "./dist/hooks/client.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "next": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "next": "^15.0.0",
    "typescript": "^5.0.0"
  }
}
